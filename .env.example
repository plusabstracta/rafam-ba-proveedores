# ─── Base de datos origen (oracle|sqlite) ───────────────────────────────────
APP_ENV=dev
LOG_LEVEL=DEBUG
DB_BACKEND=sqlite

# Oracle RAFAM (usar cuando DB_BACKEND=oracle)
DB_HOST=192.168.x.x
DB_PORT=1521
DB_SERVICE=BDRAFAM
DB_USER=usuario_lectura
DB_PASSWORD=secreto

# SQLite local (usar cuando DB_BACKEND=sqlite)
SQLITE_DB_PATH=state/dev_rafam.db

# Checkpoints locales
CHECKPOINT_DB_PATH=state/checkpoint.db
ENTITY_LINK_DB_PATH=state/checkpoint.db

# ─── Gateway / Paxapos ───────────────────────────────────────────────────────
GATEWAY_URL=https://dev2.paxapos.com
GATEWAY_TENANT=prueba
GATEWAY_JWT=your_jwt_here
GATEWAY_VERIFY_SSL=false
GATEWAY_TIMEOUT_SECONDS=20
GATEWAY_ENDPOINT_PROVEEDORES=account/proveedores.json
GATEWAY_ENDPOINT_PROVEEDORES_UPDATE=account/proveedores/edit/{id}.json
GATEWAY_LOOKUP_PROVEEDORES_INDEX=account/proveedores/index.json

# ─── RAFAM Migrator API ──────────────────────────────────────────────────────
# URL base sin tenant en path; el tenant viaja en X-Tenant-Id
MIGRATOR_BASE_URL=https://dev2.paxapos.com
MIGRATOR_TENANT=prueba
MIGRATOR_API_KEY=your_agent_api_key_here
MIGRATOR_VERIFY_SSL=false
MIGRATOR_TIMEOUT_SECONDS=20
MIGRATOR_IMPORT_ENDPOINT=rafam/migracion/importar.json
MIGRATOR_SPEC_ENDPOINT=rafam/migracion/spec.json
MIGRATOR_LOOKUPS_ENDPOINT=rafam/migracion/lookups.json
MIGRATOR_DEFAULT_UNIDAD_ID=1
MIGRATOR_DEFAULT_TIPO_FACTURA_ID=
MIGRATOR_DEFAULT_TIPO_PAGO_ID=1
MIGRATOR_BATCH_DELAY_SECONDS=2
