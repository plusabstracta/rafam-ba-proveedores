# ─── App en este servidor ────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=DEBUG

# ─── SOURCE: RAFAM ───────────────────────────────────────────────────────────
# Antes: DB_BACKEND, DB_HOST, DB_PORT, DB_SERVICE, DB_USER, DB_PASSWORD, SQLITE_DB_PATH
# oracle = RAFAM real; sqlite = snapshot local de RAFAM para desarrollo
RAFAM_SOURCE_BACKEND=sqlite

# Oracle RAFAM (usar cuando RAFAM_SOURCE_BACKEND=oracle)
RAFAM_SOURCE_HOST=192.168.x.x
RAFAM_SOURCE_PORT=1521
RAFAM_SOURCE_SERVICE=BDRAFAM
RAFAM_SOURCE_USER=usuario_lectura
RAFAM_SOURCE_PASSWORD=secreto

# Snapshot RAFAM local en este servidor (usar con RAFAM_SOURCE_BACKEND=sqlite)
RAFAM_SOURCE_SQLITE_DB_PATH=state/dev_rafam.db

# ─── LOCAL: estado del script ────────────────────────────────────────────────
# Guarda checkpoints + vínculos RAFAM -> Paxapos en una sola SQLite.
# Antes: CHECKPOINT_DB_PATH/ENTITY_LINK_DB_PATH, luego LOCAL_CHECKPOINT_DB_PATH/LOCAL_ENTITY_LINK_DB_PATH.
LOCAL_STATE_DB_PATH=state/checkpoint.db

# ─── DESTINATION: Paxapos / Portal de Proveedores ────────────────────────────
# Antes: GATEWAY_URL, GATEWAY_TENANT, GATEWAY_JWT, GATEWAY_VERIFY_SSL, GATEWAY_TIMEOUT_SECONDS,
#        MIGRATOR_BASE_URL, MIGRATOR_TENANT, MIGRATOR_API_KEY, MIGRATOR_VERIFY_SSL, MIGRATOR_TIMEOUT_SECONDS
PAXAPOS_URL=https://proveedores.madariaga.gob.ar
PAXAPOS_TENANT=madariaga
PAXAPOS_VERIFY_SSL=true
PAXAPOS_TIMEOUT_SECONDS=20
PAXAPOS_JWT=your_jwt_here
PAXAPOS_API_KEY=your_agent_api_key_here

# Endpoints directos Paxapos para proveedores (antes GATEWAY_ENDPOINT_*)
PAXAPOS_PROVEEDORES_ENDPOINT=account/proveedores.json
PAXAPOS_PROVEEDORES_UPDATE_ENDPOINT=account/proveedores/edit/{id}.json
PAXAPOS_PROVEEDORES_LOOKUP_INDEX_ENDPOINT=account/proveedores/index.json

# Rutas RAFAM dentro de Paxapos: {PAXAPOS_URL}/{PAXAPOS_TENANT}/{PAXAPOS_RAFAM_*_PATH}.
# Antes: MIGRATOR_IMPORT_ENDPOINT/MIGRATOR_SPEC_ENDPOINT/MIGRATOR_LOOKUPS_ENDPOINT.
PAXAPOS_RAFAM_IMPORT_PATH=rafam/migracion/importar.json
PAXAPOS_RAFAM_SPEC_PATH=rafam/migracion/spec.json
PAXAPOS_RAFAM_LOOKUPS_PATH=rafam/migracion/lookups.json

# IDs default de Paxapos usados cuando RAFAM no trae/mapea el valor.
# Antes: MIGRATOR_DEFAULT_UNIDAD_ID/MIGRATOR_DEFAULT_TIPO_FACTURA_ID/MIGRATOR_DEFAULT_TIPO_PAGO_ID.
PAXAPOS_RAFAM_DEFAULT_UNIDAD_ID=1
PAXAPOS_RAFAM_DEFAULT_TIPO_FACTURA_ID=
PAXAPOS_RAFAM_DEFAULT_TIPO_PAGO_ID=1

# Delay local del script entre batches enviados a Paxapos. Antes: MIGRATOR_BATCH_DELAY_SECONDS.
RAFAM_SYNC_BATCH_DELAY_SECONDS=2
